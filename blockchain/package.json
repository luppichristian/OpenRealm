{
  "name": "openrealm-blockchain",
  "version": "0.2.0",
  "private": true,
  "description": "OpenRealm orchestration-layer contracts, build scripts, deployment scripts, and tests",
  "scripts": {
    "build": "node scripts/compile.js",
    "test": "mocha --recursive --reporter spec test/**/*.test.js",
    "verify": "npm run build && npm test",
    "deploy": "node scripts/deploy.js",
    "deploy:realm": "node scripts/deployRealm.js",
    "ganache:test": "node ../realms/test/start-ganache-local.js",
    "deploy:test:local": "node ../realms/test/deploy-local.js",
    "deploy:main": "node ../realms/main/deploy.js"
  },
  "devDependencies": {
    "ethers": "^6.15.0",
    "ganache": "^7.9.2",
    "mocha": "^10.8.2",
    "solc": "^0.8.30"
  }
}
