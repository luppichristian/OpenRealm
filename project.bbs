# Using my build system https://github.com/luppichristian/bbs

id(openrealm)
name("OpenRealm")
ver(0.0.0)

targets(
  static_lib(
    id(raylib)
    name("Raylib")
    repo(
      link("https://github.com/raysan5/raylib.git")
      tag("6.0")
    )
    cmake_target(raylib)
  )

  console(
    output(openrealm)
    lang(c)
    dependencies(raylib)
    units(src/*.c)
  )
)
